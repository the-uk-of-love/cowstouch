  <style>
    .text-block { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }
    .text-block p { max-width: none; }

    .section-label { display: inline-block; background: var(--green); color: var(--cream); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.3rem 0.8rem; border-radius: 2px; margin-bottom: 1rem; }

    /* Oil ranked list — NO grid, simple flex */
    .oil-list { list-style: none; margin: 1.5rem 0; }
    .oil-list li { display: flex; gap: 1rem; padding: 1.2rem 0; border-bottom: 1px solid var(--cream-deep); align-items: flex-start; }
    .oil-list li:last-child { border-bottom: none; }
    .oil-rank { background: var(--green); color: var(--cream); width: 2.2rem; height: 2.2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 500; font-size: 0.9rem; flex-shrink: 0; margin-top: 0.2rem; }
    .oil-content { flex: 1; }
    .oil-content h4 { color: var(--green); margin-bottom: 0.2rem; font-size: 1rem; }
    .oil-content p { font-size: 0.88rem; margin: 0; max-width: none; }
    .oil-content .dosage { font-size: 0.78rem; color: var(--gold); font-weight: 500; margin-bottom: 0.2rem; }

    /* Steps — NO grid, simple flex */
    .apply-steps { list-style: none; margin: 1.5rem 0; padding: 0; }
    .apply-steps li { display: flex; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--cream-deep); align-items: flex-start; }
    .apply-steps li:last-child { border-bottom: none; }
    .step-num { font-family: var(--font-display); font-size: 1.4rem; color: var(--gold); font-weight: 300; line-height: 1.2; flex-shrink: 0; width: 2rem; text-align: center; margin-top: 0.1rem; }
    .step-content { flex: 1; }
    .step-content strong { display: block; color: var(--green); margin-bottom: 0.2rem; }
    .step-content p { font-size: 0.9rem; margin: 0; max-width: none; }

    .method-card { background: var(--white); border: 1px solid var(--cream-deep); border-radius: 4px; padding: 1.5rem; margin-bottom: 1.2rem; }
    .method-card h4 { color: var(--green); margin-bottom: 0.5rem; }
    .method-card p { font-size: 0.9rem; margin-bottom: 0.5rem; max-width: none; }
    .method-card p:last-child { margin-bottom: 0; }

    .blend-box { background: var(--green); color: var(--cream); border-radius: 6px; padding: 1.5rem 2rem; margin: 1.5rem 0; }
    .blend-box h4 { color: var(--gold-light); margin-bottom: 0.5rem; }
    .blend-box p { color: rgba(247,242,232,0.85); font-size: 0.9rem; margin: 0; max-width: none; }

    .ratio-table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
    .ratio-table th { background: var(--green); color: var(--cream); padding: 0.7rem 1rem; text-align: left; }
    .ratio-table td { padding: 0.65rem 1rem; border-bottom: 1px solid var(--cream-deep); }
    .ratio-table tr:nth-child(even) td { background: var(--cream-deep); }
