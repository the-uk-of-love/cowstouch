  <!-- Page header — green banner, no hero image -->
  <div style="background:var(--green); padding:clamp(3rem,8vw,5rem) 1.5rem 2.5rem;">
    <div style="max-width:var(--max-w); margin:0 auto;">
      <span class="eyebrow" style="color:var(--gold-light);">Complete Practical Guide</span>
      <h1 style="color:var(--cream); margin-bottom:0.5rem;">How to Apply</h1>
      <p style="color:rgba(247,242,232,0.8); font-family:var(--font-display); font-style:italic; font-size:1.2rem; margin:0;">From First Touch to Daily Practice</p>
      <p style="color:rgba(247,242,232,0.7); margin-top:0.8rem; max-width:58ch;">Everything you need to use cow urine, cow dung, ghee, and Panchagavya safely, comfortably, and effectively — with full control over odour.</p>
    </div>
  </div>

